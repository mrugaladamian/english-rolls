#!/usr/bin/env bash
set -euo pipefail

backup_name_pattern='.*/[0-9]{2}-[0-9]{2}-[0-9]{4}_[0-9]{2}-[0-9]{2}-[0-9]{2}\.zip'
project_dir=''
project_name=''
backup_dir=''

set_paths() {
    project_dir="$(pwd)"
    project_name="$(basename -- "${project_dir}")"
    backup_dir="${HOME}/codeplatform/backup/projects/${project_name}"
}

backup_files() {
    find "${backup_dir}" -maxdepth 1 -type f \
        -regextype posix-extended \
        -regex "${backup_name_pattern}" \
        -printf '%T@ %TY-%Tm-%Td %TH:%TM %s %p\n' \
        | sort -rn
}

print_backup_files() {
    local listed_backups=0
    local timestamp
    local date
    local time
    local size
    local backup_file

    printf 'Backups for %s:\n' "${project_name}"
    printf '%s\n' "${backup_dir}"
    printf '\n'

    while read -r timestamp date time size backup_file; do
        listed_backups=$((listed_backups + 1))
        printf '%2d. %s %s  %8s  %s\n' \
            "${listed_backups}" \
            "${date}" \
            "${time}" \
            "$(numfmt --to=iec --suffix=B "${size}")" \
            "${backup_file}"
    done < <(backup_files)

    if [[ "${listed_backups}" -eq 0 ]]; then
        echo "No backups found."
    fi
}

main() {
    set_paths

    if [[ ! -d "${backup_dir}" ]]; then
        echo "Backup directory does not exist: ${backup_dir}"
        exit 0
    fi

    print_backup_files
}

main "$@"
