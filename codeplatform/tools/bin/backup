#!/usr/bin/env bash
set -euo pipefail

keep_backups=20
backup_name_pattern='.*/[0-9]{2}-[0-9]{2}-[0-9]{4}_[0-9]{2}-[0-9]{2}-[0-9]{2}\.zip'
project_dir=''
project_name=''
backup_dir=''
backup_file=''

set_paths() {
    project_dir="$(pwd)"
    project_name="$(basename -- "${project_dir}")"
    backup_dir="${HOME}/codeplatform/backup/projects/${project_name}"
    backup_file="${backup_dir}/$(date '+%d-%m-%Y_%H-%M-%S').zip"
}

create_backup_dir() {
    mkdir -p -- "${backup_dir}"
}

create_backup_file() {
    (
        cd -- "$(dirname -- "${project_dir}")"
        zip -qr "${backup_file}" "${project_name}"
    )
}

old_backup_files() {
    find "${backup_dir}" -maxdepth 1 -type f \
        -regextype posix-extended \
        -regex "${backup_name_pattern}" \
        -printf '%T@ %p\n' \
        | sort -rn \
        | tail -n "+$((keep_backups + 1))" \
        | cut -d ' ' -f 2-
}

remove_old_backups() {
    local removed_backups=0
    local old_backup
    while IFS= read -r old_backup; do
        rm -f -- "${old_backup}"
        removed_backups=$((removed_backups + 1))
    done < <(old_backup_files)
    report_removed_backups "${removed_backups}"
}

report_removed_backups() {
    local removed_backups="$1"
    if [[ "${removed_backups}" -gt 0 ]]; then
        echo "Removed old backups: ${removed_backups}"
    fi
}

main() {
    set_paths
    create_backup_dir
    create_backup_file
    echo "Backup created: ${backup_file}"
    remove_old_backups
}

main "$@"
