#!/usr/bin/env bash
set -euo pipefail

backup_name_pattern='.*/[0-9]{2}-[0-9]{2}-[0-9]{4}_[0-9]{2}-[0-9]{2}-[0-9]{2}\.zip'
project_dir=''
project_name=''
backup_dir=''

set_paths() {
    project_dir="$(pwd)"
    project_name="$(basename -- "${project_dir}")"
    backup_dir="${HOME}/codeplatform/backup/projects/${project_name}"
}

latest_backup_file() {
    find "${backup_dir}" -maxdepth 1 -type f \
        -regextype posix-extended \
        -regex "${backup_name_pattern}" \
        -printf '%T@ %TY-%Tm-%Td %TH:%TM %s %p\n' \
        | sort -rn \
        | head -n 1
}

print_latest_backup_file() {
    local timestamp
    local date
    local time
    local size
    local backup_file

    if ! read -r timestamp date time size backup_file < <(latest_backup_file); then
        echo "No backups found."
        exit 0
    fi

    printf 'Last backup for %s:\n' "${project_name}"
    printf '%s %s  %s  %s\n' \
        "${date}" \
        "${time}" \
        "$(numfmt --to=iec --suffix=B "${size}")" \
        "${backup_file}"
}

main() {
    set_paths

    if [[ ! -d "${backup_dir}" ]]; then
        echo "Backup directory does not exist: ${backup_dir}"
        exit 0
    fi

    print_latest_backup_file
}

main "$@"
